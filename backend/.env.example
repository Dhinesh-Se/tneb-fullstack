# ─── Server ───────────────────────────────────────────────
PORT=5292

# ─── MongoDB ──────────────────────────────────────────────
# For local dev:  mongodb://localhost:27017/tneb_db
# For Atlas:      mongodb+srv://<user>:<pass>@cluster.mongodb.net/tneb_db
MONGO_URI=mongodb://localhost:27017/tneb_db
# Optional fallback DB name when URL has no /dbname (Railway plugin URLs, etc.)
MONGO_DB_NAME=tneb_db

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=tneb_super_secret_key_change_in_production
# Optional aliases supported by backend
JWT_KEY=
JWT_SECRET_KEY=
JWT_EXPIRES_IN=24h

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
CLIENT_URL=http://localhost:3000

# Set true to allow all origins temporarily during first deployment
ALLOW_ALL_ORIGINS=false
